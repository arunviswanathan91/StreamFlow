<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.streamflow.ui.TransformationController"
      styleClass="content" spacing="12.0">
    <children>
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>
                <Label text="Transformation" styleClass="title"/>
                <Button fx:id="aboutButton" text="What is this?" onAction="#onAbout">
                    <graphic><FontIcon iconLiteral="fas-question-circle"/></graphic>
                </Button>
            </children>
        </HBox>
        <Label text="Sets the transform that Clustering and Dim. Reduction apply to fluorescence values before they run — choose logicle here and the embedding really is computed on logicle-scaled data. It does NOT change a plot's axis scale (that is a per-plot setting in the Graph Window, and is what you want for gating and viewing), and it does NOT change the Statistics table, which reports raw values."
               styleClass="subtitle" wrapText="true"/>

        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>
                <Label text="Method:"/>
                <ComboBox fx:id="methodCombo"/>
                <Label text="Arcsinh cofactor:"/>
                <Spinner fx:id="cofactorSpinner" editable="true" prefWidth="110.0"/>
                <Button fx:id="refreshButton" text="Refresh channels" onAction="#onRefresh">
                    <graphic><FontIcon iconLiteral="fas-sync"/></graphic>
                </Button>
                <Button fx:id="applyButton" text="Apply Transform" onAction="#onApply" styleClass="primary">
                    <graphic><FontIcon iconLiteral="fas-wave-square"/></graphic>
                </Button>
            </children>
        </HBox>

        <Label text="Channels (none selected = all fluorescence channels):" styleClass="subtitle"/>
        <ListView fx:id="channelList" VBox.vgrow="ALWAYS"/>
        <Label fx:id="statusLabel" text="" styleClass="subtitle"/>
    </children>
</VBox>
