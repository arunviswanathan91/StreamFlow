<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.streamflow.ui.CrossSampleController"
      styleClass="content" spacing="12.0">
    <children>
        <Label text="Cross-Sample Analysis" styleClass="title"/>
        <Label text="Compare gated population frequencies across all opened samples: a gate×sample matrix, a per-gate consistency (CV) check, a population radar, and an MFI drift heatmap. Reads the shared workspace — open samples in graph windows to include them."
               styleClass="subtitle" wrapText="true"/>
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>
                <Button fx:id="refreshButton" text="Refresh" onAction="#onRefresh">
                    <graphic><FontIcon iconLiteral="fas-sync"/></graphic>
                </Button>
                <Label fx:id="statusLabel" text="" styleClass="subtitle"/>
            </children>
        </HBox>
        <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Gate × Sample">
                    <content>
                        <VBox spacing="6.0">
                            <children>
                                <Label text="Frequency (% of all events). Cells shaded by z-score across samples (blue=low, red=high)." styleClass="subtitle" wrapText="true"/>
                                <TableView fx:id="matrixTable" VBox.vgrow="ALWAYS"/>
                            </children>
                        </VBox>
                    </content>
                </Tab>
                <Tab text="Consistency">
                    <content>
                        <VBox spacing="6.0">
                            <children>
                                <Label text="Per-gate coefficient of variation across samples. CV &gt; 50% is flagged as inconsistent." styleClass="subtitle" wrapText="true"/>
                                <TableView fx:id="consistencyTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="cGateCol"  text="Gate"     prefWidth="220.0"/>
                                        <TableColumn fx:id="cMeanCol"  text="Mean %"   prefWidth="100.0"/>
                                        <TableColumn fx:id="cSdCol"    text="SD"       prefWidth="100.0"/>
                                        <TableColumn fx:id="cCvCol"    text="CV %"     prefWidth="100.0"/>
                                        <TableColumn fx:id="cFlagCol"  text="Status"   prefWidth="120.0"/>
                                    </columns>
                                    <placeholder><Label text="Open samples and draw gates first."/></placeholder>
                                </TableView>
                            </children>
                        </VBox>
                    </content>
                </Tab>
                <Tab text="Radar">
                    <content>
                        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="plot-pane">
                            <content>
                                <StackPane fx:id="radarHost">
                                    <children>
                                        <Canvas fx:id="radarCanvas" width="560.0" height="520.0"/>
                                    </children>
                                </StackPane>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>
                <Tab text="MFI Drift">
                    <content>
                        <VBox spacing="6.0">
                            <children>
                                <HBox spacing="8.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Population:"/>
                                        <ComboBox fx:id="driftGateCombo" prefWidth="220.0"/>
                                        <Label text="Median fluorescence per channel, per sample. Shaded blue→red by column z-score." styleClass="subtitle" wrapText="true"/>
                                    </children>
                                </HBox>
                                <TableView fx:id="driftTable" VBox.vgrow="ALWAYS"/>
                            </children>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </children>
</VBox>
