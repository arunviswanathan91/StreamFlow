<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import org.streamflow.ui.CompMatrixView?>
<?import org.streamflow.ui.CytoPlot?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.streamflow.ui.CompWizardController"
      styleClass="content" spacing="10.0" prefWidth="980.0" prefHeight="680.0">
    <children>
        <Label text="Compensation Wizard" styleClass="title"/>
        <Label text="Assign each control: pick the universal negative (unstained) and one single-stain control per detector. Detectors are auto-matched by brightest signal — override if a dot is wrong. A size-cleanup gate and positive/negative split are applied automatically; review the separation, then build the matrix."
               styleClass="subtitle" wrapText="true"/>

        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>
                <Label text="Scatter X:"/>
                <ComboBox fx:id="fscCombo" prefWidth="110.0"/>
                <Label text="Y:"/>
                <ComboBox fx:id="sscCombo" prefWidth="110.0"/>
                <Label text="Method:"/>
                <ComboBox fx:id="methodCombo" prefWidth="160.0"/>
                <CheckBox fx:id="debrisCheckBox" text="Pre-remove debris (GMM)">
                    <tooltip><Tooltip text="Remove low-FSC/SSC debris via a 2-component GMM on scatter magnitude before computing spillover. Improves accuracy when debris is present."/></tooltip>
                </CheckBox>
                <Region HBox.hgrow="ALWAYS"/>
                <ProgressIndicator fx:id="computeSpinner" prefWidth="22.0" prefHeight="22.0" visible="false"/>
                <Button fx:id="computeButton" text="Compute matrix" onAction="#onCompute" styleClass="primary">
                    <graphic><FontIcon iconLiteral="fas-calculator"/></graphic>
                </Button>
            </children>
        </HBox>

        <SplitPane fx:id="splitPane" dividerPositions="0.42" VBox.vgrow="ALWAYS">
            <items>
                <VBox spacing="6.0">
                    <children>
                        <Label text="Controls" styleClass="subtitle"/>
                        <TableView fx:id="assignTable" VBox.vgrow="ALWAYS" editable="true">
                            <columns>
                                <TableColumn fx:id="sampleCol"   text="Sample"   prefWidth="200.0"/>
                                <TableColumn fx:id="roleCol"     text="Role"     prefWidth="130.0"/>
                                <TableColumn fx:id="detectorCol" text="Detector" prefWidth="130.0"/>
                            </columns>
                        </TableView>
                        <HBox spacing="6.0" alignment="CENTER_LEFT">
                            <children>
                                <Label text="Per-stain size gate" styleClass="subtitle"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="scatterResetButton" text="Reset" onAction="#onResetScatterGate"/>
                            </children>
                        </HBox>
                        <Label text="Click a row above to view that stain's scatter. Drag the box to set its cleanup gate — each stain remembers its own." styleClass="subtitle" wrapText="true"/>
                        <CytoPlot fx:id="scatterPlot" prefHeight="260.0" minHeight="200.0"/>
                    </children>
                </VBox>
                <VBox spacing="6.0">
                    <children>
                        <Label text="Positive / negative separation  —  drag the dashed line to adjust each split" styleClass="subtitle"/>
                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="plot-pane">
                            <content>
                                <FlowPane fx:id="histBox" hgap="8.0" vgap="8.0"/>
                            </content>
                        </ScrollPane>
                        <Label text="Computed spillover" styleClass="subtitle"/>
                        <CompMatrixView fx:id="wizardHeatmap" prefHeight="300.0" minHeight="260.0"/>
                    </children>
                </VBox>
            </items>
        </SplitPane>

        <Label fx:id="statusLabel" text="" styleClass="subtitle"/>
        <HBox spacing="8.0" alignment="CENTER_RIGHT">
            <children>
                <Button fx:id="useButton" text="Use this matrix" onAction="#onUse" styleClass="primary">
                    <graphic><FontIcon iconLiteral="fas-check"/></graphic>
                </Button>
                <Button fx:id="closeButton" text="Close" onAction="#onClose"/>
            </children>
        </HBox>
    </children>
</VBox>
