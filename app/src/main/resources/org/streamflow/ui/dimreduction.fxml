<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.streamflow.ui.DimReductionController"
      styleClass="content" spacing="12.0">
    <children>
        <Label text="Dimensionality Reduction" styleClass="title"/>
        <Label text="UMAP / t-SNE on a sample's fluorescence channels. Runs in the background — the UI stays responsive."
               styleClass="subtitle" wrapText="true"/>
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>
                <Label text="Method:"/>
                <ComboBox fx:id="methodCombo"/>
                <Label text="Sample:"/>
                <ComboBox fx:id="sampleCombo" prefWidth="220.0"/>
                <Label text="Events:"/>
                <Spinner fx:id="eventsSpinner" editable="true" prefWidth="120.0"/>
                <Button fx:id="refreshButton" text="Refresh" onAction="#onRefresh">
                    <graphic><FontIcon iconLiteral="fas-sync"/></graphic>
                </Button>
                <Button fx:id="runButton" text="Run" onAction="#onRun" styleClass="primary">
                    <graphic><FontIcon iconLiteral="fas-project-diagram"/></graphic>
                </Button>
            </children>
        </HBox>
        <Label fx:id="statusLabel" text="" styleClass="subtitle"/>
        <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" styleClass="plot-pane">
            <content>
                <StackPane>
                    <children>
                        <ImageView fx:id="mapView"/>
                    </children>
                </StackPane>
            </content>
        </ScrollPane>
    </children>
</VBox>
