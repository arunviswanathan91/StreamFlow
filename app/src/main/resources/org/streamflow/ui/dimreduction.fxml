<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.streamflow.ui.DimReductionController"
      styleClass="content" spacing="12.0">
    <children>
        <Label text="Dimensionality Reduction" styleClass="title"/>
        <Label text="UMAP / t-SNE on a sample's fluorescence channels. Runs in the background — the UI stays responsive."
               styleClass="subtitle" wrapText="true"/>
        <VBox fx:id="hintPane" styleClass="workflow-hints" managed="false" visible="false" spacing="6.0"/>
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>
                <Label text="Method:"/>
                <ComboBox fx:id="methodCombo"/>
                <Label text="Sample:"/>
                <ComboBox fx:id="sampleCombo" prefWidth="220.0"/>
                <Label text="Events:"/>
                <Spinner fx:id="eventsSpinner" editable="true" prefWidth="120.0"/>
                <Button fx:id="refreshButton" text="Refresh" onAction="#onRefresh">
                    <graphic><FontIcon iconLiteral="fas-sync"/></graphic>
                </Button>
                <Button fx:id="runButton" text="Run" onAction="#onRun" styleClass="primary">
                    <graphic><FontIcon iconLiteral="fas-project-diagram"/></graphic>
                </Button>
                <Button fx:id="copyButton" text="Copy" onAction="#onCopy">
                    <graphic><FontIcon iconLiteral="fas-copy"/></graphic>
                </Button>
                <Button fx:id="exportButton" text="Export PNG" onAction="#onExport">
                    <graphic><FontIcon iconLiteral="fas-download"/></graphic>
                </Button>
            </children>
        </HBox>
        <Label fx:id="statusLabel" text="" styleClass="subtitle"/>
        <StackPane fx:id="mapPane" VBox.vgrow="ALWAYS" styleClass="plot-pane">
            <children>
                <Canvas fx:id="mapCanvas"/>
            </children>
        </StackPane>
    </children>
</VBox>
