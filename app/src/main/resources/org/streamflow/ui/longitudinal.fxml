<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.streamflow.ui.LongitudinalController"
      styleClass="content" spacing="12.0">
    <children>
        <Label text="Longitudinal Tracking" styleClass="title"/>
        <Label text="Track a gate's frequency across timepoints per subject. Assign each opened sample a subject and a numeric timepoint, pick a gate, and plot the trajectory — for treatment-response and time-series studies."
               styleClass="subtitle" wrapText="true"/>
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>
                <Label text="Gate:"/>
                <ComboBox fx:id="gateCombo" prefWidth="220.0"/>
                <Button fx:id="refreshButton" text="Refresh" onAction="#onRefresh">
                    <graphic><FontIcon iconLiteral="fas-sync"/></graphic>
                </Button>
                <Button fx:id="plotButton" text="Plot" onAction="#onPlot" styleClass="primary">
                    <graphic><FontIcon iconLiteral="fas-chart-line"/></graphic>
                </Button>
            </children>
        </HBox>
        <Label fx:id="statusLabel" text="" styleClass="subtitle"/>
        <HBox spacing="12.0" VBox.vgrow="ALWAYS">
            <children>
                <LineChart fx:id="chart" HBox.hgrow="ALWAYS" createSymbols="true" animated="false">
                    <xAxis><NumberAxis fx:id="xAxis" label="Timepoint" forceZeroInRange="false"/></xAxis>
                    <yAxis><NumberAxis fx:id="yAxis" label="\% of all events"/></yAxis>
                </LineChart>
                <VBox spacing="6.0" prefWidth="320.0" minWidth="280.0" HBox.hgrow="NEVER">
                    <children>
                        <Label text="Samples" styleClass="title"/>
                        <Label text="Assign subject + numeric timepoint:" styleClass="subtitle" wrapText="true"/>
                        <TableView fx:id="sampleTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="sampleCol"   text="Sample"    prefWidth="150.0"/>
                                <TableColumn fx:id="subjectCol"  text="Subject"   prefWidth="90.0"/>
                                <TableColumn fx:id="timeCol"     text="Timepoint" prefWidth="80.0"/>
                            </columns>
                            <placeholder><Label text="Open samples in graph windows first."/></placeholder>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
