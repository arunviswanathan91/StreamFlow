<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.streamflow.ui.GraphWindowController" styleClass="app-root">
    <fx:define>
        <ToggleGroup fx:id="toolGroup"/>
    </fx:define>

    <top>
        <VBox>
            <children>
                <ToolBar styleClass="statusbar">
                    <items>
                        <Button fx:id="prevSampleButton" text="◀">
                            <tooltip><Tooltip text="Previous sample (Left arrow)"/></tooltip>
                        </Button>
                        <ComboBox fx:id="sampleJumpCombo" prefWidth="200.0"/>
                        <Button fx:id="nextSampleButton" text="▶">
                            <tooltip><Tooltip text="Next sample (Right arrow)"/></tooltip>
                        </Button>
                        <Separator orientation="VERTICAL"/>
                        <Label text="Plot:"/>
                        <ComboBox fx:id="plotTypeCombo"/>
                        <Separator orientation="VERTICAL"/>
                        <Label text="Gate:" style="-fx-text-fill:#EAEFF5;"/>
                        <ToggleButton fx:id="toolNoneBtn" toggleGroup="$toolGroup" selected="true" styleClass="tool-btn">
                            <graphic><FontIcon iconLiteral="fas-mouse-pointer"/></graphic>
                            <tooltip><Tooltip text="No gate tool — select / move (N)"/></tooltip>
                        </ToggleButton>
                        <ToggleButton fx:id="toolPolyBtn" toggleGroup="$toolGroup" styleClass="tool-btn">
                            <graphic><FontIcon iconLiteral="fas-draw-polygon"/></graphic>
                            <tooltip><Tooltip text="Polygon gate (P)"/></tooltip>
                        </ToggleButton>
                        <ToggleButton fx:id="toolRectBtn" toggleGroup="$toolGroup" styleClass="tool-btn">
                            <graphic><FontIcon iconLiteral="fas-vector-square"/></graphic>
                            <tooltip><Tooltip text="Rectangle gate (R)"/></tooltip>
                        </ToggleButton>
                        <ToggleButton fx:id="toolEllipseBtn" toggleGroup="$toolGroup" styleClass="tool-btn">
                            <graphic><FontIcon iconLiteral="far-circle"/></graphic>
                            <tooltip><Tooltip text="Ellipse gate (E)"/></tooltip>
                        </ToggleButton>
                        <ToggleButton fx:id="toolIntervalBtn" toggleGroup="$toolGroup" styleClass="tool-btn">
                            <graphic><FontIcon iconLiteral="fas-ruler-horizontal"/></graphic>
                            <tooltip><Tooltip text="Interval gate (I)"/></tooltip>
                        </ToggleButton>
                        <ToggleButton fx:id="toolQuadBtn" toggleGroup="$toolGroup" styleClass="tool-btn">
                            <graphic><FontIcon iconLiteral="fas-th"/></graphic>
                            <tooltip><Tooltip text="Quadrant gate (Q)"/></tooltip>
                        </ToggleButton>
                        <Separator orientation="VERTICAL"/>
                        <Button fx:id="channelsButton" text="Channels…" onAction="#onChannels">
                            <tooltip><Tooltip text="Name detector channels with their target (CD4 …)"/></tooltip>
                        </Button>
                        <Button fx:id="copyButton" text="Copy" onAction="#onCopy">
                            <tooltip><Tooltip text="Copy plot image to clipboard using the current Copy format"/></tooltip>
                        </Button>
                        <Button fx:id="copySettingsButton" onAction="#onCopySettings">
                            <tooltip><Tooltip text="Copy format — set font, axis, point size &amp; DPI for every Copy (app-wide)"/></tooltip>
                        </Button>
                        <Button fx:id="svgButton" text="SVG" onAction="#onSaveSvg">
                            <tooltip><Tooltip text="Save the plot as an editable SVG vector file"/></tooltip>
                        </Button>
                        <Separator orientation="VERTICAL"/>
                        <Button fx:id="undoButton" text="Undo" onAction="#onUndo">
                            <graphic><FontIcon iconLiteral="fas-undo"/></graphic>
                            <tooltip><Tooltip text="Undo the last gate change (Ctrl+Z)"/></tooltip>
                        </Button>
                        <Button fx:id="redoButton" text="Redo" onAction="#onRedo">
                            <graphic><FontIcon iconLiteral="fas-redo"/></graphic>
                            <tooltip><Tooltip text="Redo (Ctrl+Y / Ctrl+Shift+Z)"/></tooltip>
                        </Button>
                        <Separator orientation="VERTICAL"/>
                        <Button fx:id="fmoButton" text="Set FMO" onAction="#onSetFmo">
                            <tooltip><Tooltip text="Mark this sample as the FMO control for the shown channel(s): draws a dashed 95th-percentile reference line on every plot of that channel. Shift-click to clear."/></tooltip>
                        </Button>
                        <Button fx:id="compareButton" text="Compare" onAction="#onCompareStrip">
                            <tooltip><Tooltip text="Show this population on the same axes across all opened samples; click a thumbnail to open that sample."/></tooltip>
                        </Button>
                        <MenuButton fx:id="jumpButton" text="Jump">
                            <tooltip><Tooltip text="Switch focus to another currently-open Graph Window"/></tooltip>
                        </MenuButton>
                    </items>
                </ToolBar>
                <HBox fx:id="breadcrumbBar" styleClass="statusbar" spacing="2.0"/>
                <HBox fx:id="downsampleBanner" spacing="6.0" alignment="CENTER_LEFT"
                      managed="false" visible="false"
                      style="-fx-background-color:#FFF3CD;-fx-border-color:#FFC107;-fx-border-width:0 0 1 0;-fx-padding:3 12 3 12;">
                    <children>
                        <Label text="⚠" style="-fx-font-size:11;-fx-text-fill:#856404;"/>
                        <Label fx:id="downsampleLabel" text="" style="-fx-font-size:11;-fx-text-fill:#856404;"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <left>
        <VBox alignment="CENTER" styleClass="content" spacing="6.0" prefWidth="150.0" minWidth="150.0" maxWidth="150.0">
            <children>
                <Label text="Y" styleClass="subtitle"/>
                <ComboBox fx:id="yAxisCombo" prefWidth="130.0"/>
                <ComboBox fx:id="yScaleCombo" prefWidth="110.0"/>
                <Button fx:id="yAxisOptsButton" text="⚙">
                    <tooltip><Tooltip text="Adjust Y axis scale (width / cofactor / range)"/></tooltip>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="plotHost"/>
    </center>

    <right>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefWidth="260.0" minWidth="260.0" maxWidth="260.0" minHeight="0.0"
                    style="-fx-background-color:transparent;">
            <content>
        <VBox styleClass="content" spacing="6.0">
            <children>
                <Label text="Gating tree" styleClass="subtitle"/>
                <Label text="(click a population to view it)" styleClass="subtitle" wrapText="true"/>
                <TreeView fx:id="gateTree" prefHeight="220.0" minHeight="160.0"/>
                <Button fx:id="removeGateButton" text="Remove population" onAction="#onRemoveGate"/>

                <TitledPane text="Options" expanded="true" collapsible="true" animated="true">
                    <VBox spacing="5.0" style="-fx-padding:6;">
                        <CheckBox fx:id="lightModeCheck" text="Light background">
                            <tooltip><Tooltip text="Switch the plot to a white background for printing/export"/></tooltip>
                        </CheckBox>
                        <CheckBox fx:id="labelsVisibleCheck" text="Show gate labels" selected="true">
                            <tooltip><Tooltip text="Toggle visibility of all gate name/stat labels on the plot"/></tooltip>
                        </CheckBox>
                        <CheckBox fx:id="fmoVisibleCheck" text="Show FMO lines" selected="true">
                            <tooltip><Tooltip text="Hide the FMO reference lines without clearing them (Set FMO clears/re-sets, Shift-click clears)"/></tooltip>
                        </CheckBox>
                        <CheckBox fx:id="snapCheck" text="Snap" selected="false">
                            <tooltip><Tooltip text="Magnetically snap gate edges to density valleys while gating (off by default)"/></tooltip>
                        </CheckBox>
                        <CheckBox fx:id="confidenceCheck" text="Confidence" selected="false">
                            <tooltip><Tooltip text="Gate fill turns green/yellow/red to show how cleanly the boundary separates populations. Updates live as you move gates (off by default)"/></tooltip>
                        </CheckBox>
                        <CheckBox fx:id="backgateCheck" text="Backgate" selected="false">
                            <tooltip><Tooltip text="When on, selecting a descendant population overlays its events (orange) on the current plot instead of drilling in (off by default)"/></tooltip>
                        </CheckBox>
                        <HBox spacing="6.0" alignment="CENTER_LEFT">
                            <children>
                                <Label text="Backgate color:" minWidth="100"/>
                                <ColorPicker fx:id="backgateColorPicker"/>
                            </children>
                        </HBox>
                        <Separator/>
                        <CheckBox fx:id="interceptCheck" text="X/Y intercept lines">
                            <tooltip><Tooltip text="FlowJo-style dashed reference crosshair at a fixed X/Y data value"/></tooltip>
                        </CheckBox>
                        <HBox spacing="6.0" alignment="CENTER_LEFT">
                            <children>
                                <Label text="X:" minWidth="16"/>
                                <TextField fx:id="interceptXField" text="0" prefWidth="64.0"/>
                                <Label text="Y:" minWidth="16"/>
                                <TextField fx:id="interceptYField" text="0" prefWidth="64.0"/>
                            </children>
                        </HBox>
                    </VBox>
                </TitledPane>

                <TitledPane fx:id="histGroup" text="Histogram" expanded="false" animated="true">
                    <VBox spacing="5.0" style="-fx-padding:6;">
                        <CheckBox fx:id="smoothCheck" text="Smooth" selected="true">
                            <tooltip><Tooltip text="KDE-smooth the histogram trace (histogram plots only)"/></tooltip>
                        </CheckBox>
                        <Label text="Mode:"/>
                        <ComboBox fx:id="histModeCombo" maxWidth="Infinity"/>
                        <Label text="Bandwidth:"/>
                        <Slider fx:id="bandwidthSlider" min="0.0" max="1.0" value="0.5">
                            <tooltip><Tooltip text="Histogram smoothing bandwidth"/></tooltip>
                        </Slider>
                    </VBox>
                </TitledPane>

                <TitledPane fx:id="densityGroup" text="Density" expanded="false" animated="true">
                    <VBox spacing="5.0" style="-fx-padding:6;">
                        <!-- Context-sensitive: "Point size" for pseudocolor/dot, "Smoothing" for contour/density/zebra -->
                        <Label fx:id="sizeControlLabel" text="Point size: 0" minWidth="140.0"/>
                        <Slider fx:id="sizeControlSlider" min="0" max="10" value="0" majorTickUnit="2" showTickMarks="true">
                            <tooltip><Tooltip text="Pseudocolor/dot: dot size. Contour/density/zebra: smoothing strength."/></tooltip>
                        </Slider>
                        <CheckBox fx:id="smoothDensityCheck" text="Smooth" selected="true">
                            <tooltip><Tooltip text="Blur the density field before rendering (dot/density/zebra/contour)"/></tooltip>
                        </CheckBox>
                        <Label text="Density palette:"/>
                        <ComboBox fx:id="paletteCombo" maxWidth="Infinity"/>
                        <HBox spacing="6.0" alignment="CENTER_LEFT">
                            <children>
                                <Label text="Point / dot:" minWidth="86"/>
                                <ColorPicker fx:id="dotColorPicker"/>
                            </children>
                        </HBox>
                    </VBox>
                </TitledPane>

                <TitledPane fx:id="contourGroup" text="Contour plot" expanded="false" animated="true">
                    <VBox spacing="5.0" style="-fx-padding:6;">
                        <CheckBox fx:id="contourSmoothCheck" text="Contour smooth" selected="true"/>
                        <Label fx:id="contourLevelsLabel" text="Contour lines: 10" minWidth="140.0"/>
                        <Slider fx:id="contourLevelsSlider" min="3" max="30" value="10" majorTickUnit="9" showTickMarks="true">
                            <tooltip><Tooltip text="Number of iso-density contour lines — more lines = finer detail"/></tooltip>
                        </Slider>
                        <HBox spacing="6.0" alignment="CENTER_LEFT">
                            <children>
                                <Label text="Contour line:" minWidth="86"/>
                                <ColorPicker fx:id="contourColorPicker"/>
                            </children>
                        </HBox>
                        <CheckBox fx:id="contourOutliersCheck" text="Show outliers">
                            <tooltip><Tooltip text="Draw individual events that fall outside the outermost contour (sparse tails)"/></tooltip>
                        </CheckBox>
                        <Label fx:id="outlierSizeLabel" text="Outlier size:" minWidth="140.0"/>
                        <Slider fx:id="outlierSizeSlider" min="0" max="6" value="0" majorTickUnit="1" showTickMarks="true" snapToTicks="true" disable="true">
                            <tooltip><Tooltip text="Enlarge outlier dots (enabled once 'Show outliers' is on)"/></tooltip>
                        </Slider>
                    </VBox>
                </TitledPane>

                <TitledPane text="Gate color" expanded="false" animated="true">
                    <VBox spacing="5.0" style="-fx-padding:6;">
                        <HBox spacing="6.0" alignment="CENTER_LEFT">
                            <children>
                                <Label text="Gate border:" minWidth="100"/>
                                <ColorPicker fx:id="gateBorderColorPicker"/>
                            </children>
                        </HBox>
                        <HBox spacing="6.0" alignment="CENTER_LEFT">
                            <children>
                                <Label text="Gate overlay:" minWidth="100"/>
                                <ColorPicker fx:id="gateFillColorPicker"/>
                            </children>
                        </HBox>
                        <Label text="Overlay transparency:"/>
                        <Slider fx:id="gateOpacitySlider" min="0.0" max="1.0" value="0.12" showTickLabels="true" majorTickUnit="0.25"/>
                        <HBox spacing="6.0" alignment="CENTER_LEFT">
                            <children>
                                <Label text="Name text color:" minWidth="100"/>
                                <ColorPicker fx:id="gateTextColorPicker"/>
                            </children>
                        </HBox>
                        <CheckBox fx:id="gateTextShadowCheck" text="Name text shadow"/>
                        <HBox spacing="6.0" alignment="CENTER_LEFT">
                            <children>
                                <Label text="Shadow color:" minWidth="100"/>
                                <ColorPicker fx:id="gateShadowColorPicker"/>
                            </children>
                        </HBox>
                        <Label text="Shadow transparency:"/>
                        <Slider fx:id="gateShadowOpacitySlider" min="0.0" max="1.0" value="0.6" showTickLabels="true" majorTickUnit="0.25"/>
                    </VBox>
                </TitledPane>
            </children>
        </VBox>
            </content>
        </ScrollPane>
    </right>

    <bottom>
        <VBox>
            <children>
                <HBox alignment="CENTER" styleClass="content" spacing="8.0">
                    <children>
                        <Label text="X" styleClass="subtitle"/>
                        <ComboBox fx:id="xAxisCombo" prefWidth="170.0"/>
                        <ComboBox fx:id="xScaleCombo" prefWidth="110.0"/>
                        <Button fx:id="xAxisOptsButton" text="⚙">
                            <tooltip><Tooltip text="Adjust X axis scale (width / cofactor / range)"/></tooltip>
                        </Button>
                        <Region HBox.hgrow="ALWAYS"/>
                    </children>
                </HBox>
                <HBox style="-fx-background-color:#0A1525; -fx-padding:2 8 2 8;">
                    <Label text="P Polygon · R Rect · E Ellipse · I Interval · Q Quadrant · N None · Del Remove · Ctrl+Z Undo · Ctrl+Y Redo · Ctrl+C Copy gate · Ctrl+V Paste · ← → Navigate"
                           style="-fx-font-size:10; -fx-text-fill:#374E6A;"/>
                </HBox>
                <HBox styleClass="statusbar">
                    <children>
                        <Label fx:id="statusLabel" text="" styleClass="subtitle"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </bottom>

</BorderPane>
