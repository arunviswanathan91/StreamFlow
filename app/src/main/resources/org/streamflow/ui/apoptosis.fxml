<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import org.streamflow.ui.CytoPlot?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.streamflow.ui.ApoptosisController"
      styleClass="content" spacing="12.0">
    <children>
        <Label text="Apoptosis Analysis" styleClass="title"/>
        <Label text="Annexin V + PI (or 7-AAD) quadrant analysis. Thresholds are detected automatically at density valleys. Drag the quadrant crosshair to adjust thresholds — percentages update live."
               styleClass="subtitle" wrapText="true"/>
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>
                <Label text="Sample:"/>
                <ComboBox fx:id="sampleCombo" prefWidth="200.0"/>
                <Label text="Annexin V channel:"/>
                <ComboBox fx:id="annexinCombo" prefWidth="160.0"/>
                <Label text="PI / viability channel:"/>
                <ComboBox fx:id="piCombo" prefWidth="160.0"/>
                <Button fx:id="refreshButton" text="Refresh" onAction="#onRefresh">
                    <graphic><FontIcon iconLiteral="fas-sync"/></graphic>
                </Button>
                <Button fx:id="runButton" text="Analyse" onAction="#onRun" styleClass="primary">
                    <graphic><FontIcon iconLiteral="fas-dot-circle"/></graphic>
                </Button>
                <Separator orientation="VERTICAL"/>
                <Button fx:id="copyButton" text="Copy" onAction="#onCopy">
                    <graphic><FontIcon iconLiteral="fas-copy"/></graphic>
                </Button>
                <Button fx:id="exportPngButton" text="PNG" onAction="#onExportPng">
                    <graphic><FontIcon iconLiteral="fas-image"/></graphic>
                </Button>
            </children>
        </HBox>
        <Label fx:id="statusLabel" text="" styleClass="subtitle"/>
        <HBox spacing="12.0" VBox.vgrow="ALWAYS">
            <children>
                <CytoPlot fx:id="plot" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"/>
                <VBox spacing="6.0" prefWidth="260.0">
                    <children>
                        <Label text="Quadrant Results" styleClass="title"/>
                        <TableView fx:id="quadTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="quadNameCol" text="Population" prefWidth="140.0"/>
                                <TableColumn fx:id="quadPctCol"  text="\%" prefWidth="70.0"/>
                                <TableColumn fx:id="quadNCol"    text="Count" prefWidth="80.0"/>
                            </columns>
                            <placeholder><Label text="Run analysis to see results."/></placeholder>
                        </TableView>
                        <Label text="Thresholds (drag crosshair to adjust)" styleClass="subtitle"/>
                        <Label fx:id="annexinThreshLabel" text="Annexin V threshold: —"/>
                        <Label fx:id="piThreshLabel"      text="PI threshold: —"/>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
