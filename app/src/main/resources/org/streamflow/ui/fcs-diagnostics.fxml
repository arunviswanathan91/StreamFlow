<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.streamflow.ui.FcsDiagnosticsController"
      styleClass="content" spacing="8.0" prefWidth="740.0" prefHeight="640.0">
    <children>
        <Label fx:id="titleLabel" text="FCS Diagnostics" styleClass="title"/>
        <Label fx:id="qcLabel" text="" styleClass="subtitle" wrapText="true"/>

        <TabPane fx:id="tabs" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Summary">
                    <content>
                        <TableView fx:id="summaryTable">
                            <columns>
                                <TableColumn fx:id="sumKeyCol" text="Property" prefWidth="240.0"/>
                                <TableColumn fx:id="sumValCol" text="Value"    prefWidth="460.0"/>
                            </columns>
                            <placeholder><Label text="Loading…"/></placeholder>
                        </TableView>
                    </content>
                </Tab>
                <Tab text="Parameters / Channels">
                    <content>
                        <TableView fx:id="paramTable">
                            <columns>
                                <TableColumn fx:id="pIdxCol"    text="#"        prefWidth="40.0"/>
                                <TableColumn fx:id="pNameCol"   text="Detector" prefWidth="150.0"/>
                                <TableColumn fx:id="pMarkerCol" text="Marker"   prefWidth="160.0"/>
                                <TableColumn fx:id="pRangeCol"  text="Range"    prefWidth="90.0"/>
                                <TableColumn fx:id="pBitsCol"   text="Bits"     prefWidth="60.0"/>
                                <TableColumn fx:id="pScaleCol"  text="Amp (PnE)" prefWidth="120.0"/>
                            </columns>
                            <placeholder><Label text="Loading…"/></placeholder>
                        </TableView>
                    </content>
                </Tab>
                <Tab text="All Keywords">
                    <content>
                        <VBox spacing="6.0">
                            <children>
                                <TextField fx:id="searchField" promptText="Filter keywords…"/>
                                <TableView fx:id="kwTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="kwKeyCol" text="Keyword" prefWidth="260.0"/>
                                        <TableColumn fx:id="kwValCol" text="Value"   prefWidth="440.0"/>
                                    </columns>
                                    <placeholder><Label text="Loading…"/></placeholder>
                                </TableView>
                            </children>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>

        <HBox spacing="8.0" alignment="CENTER_RIGHT">
            <children>
                <Label fx:id="statusLabel" text="" styleClass="subtitle"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="closeButton" text="Close" onAction="#onClose" styleClass="primary"/>
            </children>
        </HBox>
    </children>
</VBox>
