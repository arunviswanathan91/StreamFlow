<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.streamflow.ui.ClassifierController"
      styleClass="content" spacing="12.0">
    <children>
        <Label text="Sample Classifier (PCA / RF)" styleClass="title"/>
        <Label text="Builds a feature vector per sample from all gate frequencies and runs PCA. If group labels are assigned, adds a Random Forest to rank which gates drive separation. CITRUS-style — absent from FlowJo."
               styleClass="subtitle" wrapText="true"/>
        <VBox fx:id="hintPane" styleClass="workflow-hints" managed="false" visible="false" spacing="6.0"/>
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>
                <Button fx:id="refreshButton" text="Refresh features" onAction="#onRefresh">
                    <graphic><FontIcon iconLiteral="fas-sync"/></graphic>
                </Button>
                <Button fx:id="runButton" text="Run PCA" onAction="#onRun" styleClass="primary">
                    <graphic><FontIcon iconLiteral="fas-brain"/></graphic>
                </Button>
                <Button fx:id="copyButton" text="Copy" onAction="#onCopy">
                    <graphic><FontIcon iconLiteral="fas-copy"/></graphic>
                </Button>
                <Button fx:id="exportButton" text="Export PNG" onAction="#onExport">
                    <graphic><FontIcon iconLiteral="fas-download"/></graphic>
                </Button>
                <Label fx:id="featCountLabel" text="" styleClass="subtitle"/>
            </children>
        </HBox>
        <Label fx:id="statusLabel" text="" styleClass="subtitle"/>
        <HBox spacing="12.0" VBox.vgrow="ALWAYS">
            <children>
                <StackPane fx:id="biplotPane" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" styleClass="plot-pane">
                    <children>
                        <Canvas fx:id="biplotCanvas"/>
                    </children>
                </StackPane>
                <VBox spacing="6.0" prefWidth="300.0" minWidth="260.0" HBox.hgrow="NEVER">
                    <children>
                        <Label text="Samples / Groups" styleClass="title"/>
                        <Label text="Tick the samples to include; assign group labels to add Random Forest:" styleClass="subtitle" wrapText="true"/>
                        <HBox spacing="6.0">
                            <children>
                                <Button fx:id="selectAllButton" text="All" onAction="#onSelectAll"/>
                                <Button fx:id="selectNoneButton" text="None" onAction="#onSelectNone"/>
                            </children>
                        </HBox>
                        <TableView fx:id="sampleTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="useCol"    text="Use"    prefWidth="44.0"/>
                                <TableColumn fx:id="sampleCol" text="Sample" prefWidth="150.0"/>
                                <TableColumn fx:id="groupCol"  text="Group"  prefWidth="100.0"/>
                            </columns>
                            <placeholder><Label text="Load FCS first."/></placeholder>
                        </TableView>
                        <Label text="Top loadings" styleClass="title"/>
                        <TableView fx:id="loadingTable" prefHeight="160.0">
                            <columns>
                                <TableColumn fx:id="featCol" text="Feature" prefWidth="180.0"/>
                                <TableColumn fx:id="pc1Col"  text="PC1"     prefWidth="60.0"/>
                                <TableColumn fx:id="pc2Col"  text="PC2"     prefWidth="60.0"/>
                            </columns>
                            <placeholder><Label text="—"/></placeholder>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
