<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.streamflow.ui.MainController" styleClass="app-root">

    <top>
        <MenuBar>
            <menus>
                <Menu text="File">
                    <items>
                        <MenuItem text="Load FCS…" onAction="#onLoadFcs"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Open Workspace…" onAction="#onOpenWorkspace"/>
                        <MenuItem text="Save Workspace…" onAction="#onSaveWorkspace"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Settings…" onAction="#onSettings"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Exit" onAction="#onExit"/>
                    </items>
                </Menu>
                <Menu text="Help">
                    <items>
                        <MenuItem text="About StreamFLOW" onAction="#onSettings"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <left>
        <VBox styleClass="sidebar" prefWidth="220.0">
            <children>
                <Label text="StreamFLOW" styleClass="brand"/>
                <ListView fx:id="navList" VBox.vgrow="ALWAYS"/>
            </children>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane"/>
    </center>

    <bottom>
        <HBox styleClass="statusbar" spacing="10.0">
            <children>
                <Label fx:id="statusLabel" text="Idle"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ProgressBar fx:id="progressBar" prefWidth="180.0" progress="0.0"/>
                <Button fx:id="cancelButton" text="Cancel"/>
                <Label fx:id="engineLabel" text="Engine: starting…" styleClass="engine-status"/>
            </children>
        </HBox>
    </bottom>

</BorderPane>
