<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.streamflow.ui.VisualizationController"
      styleClass="content" spacing="12.0">
    <children>
        <Label text="Visualization" styleClass="title"/>
        <Label text="Render a density scatter or histogram for a sample. Uses the most-processed data (transformed › compensated › raw)."
               styleClass="subtitle" wrapText="true"/>

        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>
                <Label text="Sample:"/>
                <ComboBox fx:id="sampleCombo" prefWidth="220.0"/>
                <Label text="X:"/>
                <ComboBox fx:id="xCombo" prefWidth="140.0"/>
                <Label text="Y:"/>
                <ComboBox fx:id="yCombo" prefWidth="140.0"/>
                <Label text="Type:"/>
                <ComboBox fx:id="typeCombo" prefWidth="120.0"/>
                <Button fx:id="refreshButton" text="Refresh" onAction="#onRefresh">
                    <graphic><FontIcon iconLiteral="fas-sync"/></graphic>
                </Button>
                <Button fx:id="renderButton" text="Render" onAction="#onRender" styleClass="primary">
                    <graphic><FontIcon iconLiteral="fas-chart-area"/></graphic>
                </Button>
            </children>
        </HBox>
        <Label fx:id="statusLabel" text="" styleClass="subtitle"/>

        <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" styleClass="plot-pane">
            <content>
                <StackPane>
                    <children>
                        <ImageView fx:id="plotView"/>
                    </children>
                </StackPane>
            </content>
        </ScrollPane>
    </children>
</VBox>
