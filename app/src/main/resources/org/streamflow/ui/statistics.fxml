<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.streamflow.ui.StatisticsController"
      styleClass="content" spacing="10.0">
    <children>
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>
                <Label text="Statistics" styleClass="title"/>
                <Button fx:id="helpButton" text="What is this?" onAction="#onHelp">
                    <graphic><FontIcon iconLiteral="fas-question-circle"/></graphic>
                </Button>
            </children>
        </HBox>
        <Label text="Per-sample × per-population count, % of parent/total, and one statistic per channel, computed from the gating tree. Choose which populations to include on the left."
               styleClass="subtitle" wrapText="true"/>

        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>
                <Label text="Channel statistic:"/>
                <ComboBox fx:id="statCombo" prefWidth="170.0">
                    <tooltip><Tooltip text="Which statistic the per-channel columns report. Geometric mean excludes events at or below zero."/></tooltip>
                </ComboBox>
                <Label text="Percentile:"/>
                <TextField fx:id="pctField" text="50" prefWidth="60.0"/>
                <Button fx:id="computeButton" text="Compute" onAction="#onCompute" styleClass="primary">
                    <graphic><FontIcon iconLiteral="fas-calculator"/></graphic>
                </Button>
                <Button fx:id="refreshButton" text="Refresh populations" onAction="#onRefresh">
                    <graphic><FontIcon iconLiteral="fas-sync"/></graphic>
                </Button>
                <Button fx:id="exportButton" text="Export CSV" onAction="#onExport">
                    <graphic><FontIcon iconLiteral="fas-file-csv"/></graphic>
                </Button>
            </children>
        </HBox>
        <Label fx:id="statusLabel" text="" styleClass="subtitle"/>

        <SplitPane dividerPositions="0.24" VBox.vgrow="ALWAYS">
            <items>
                <VBox spacing="4.0" styleClass="content">
                    <children>
                        <Label text="Populations" styleClass="subtitle"/>
                        <Label text="(Ctrl/Shift-click to multi-select · none = all)" styleClass="subtitle" wrapText="true"/>
                        <ListView fx:id="popList" VBox.vgrow="ALWAYS">
                            <tooltip><Tooltip text="Select which gated populations to include in the table"/></tooltip>
                        </ListView>
                    </children>
                </VBox>
                <TableView fx:id="table"/>
            </items>
        </SplitPane>
    </children>
</VBox>
