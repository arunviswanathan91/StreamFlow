<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.streamflow.ui.AnalysisLogController"
      styleClass="content" spacing="12.0">
    <children>
        <Label text="Analysis Log" styleClass="title"/>
        <Label text="Timestamped record of all gating and analysis operations. Export as a Methods paragraph for manuscript methods sections — a feature absent from both FlowJo and FCS Express."
               styleClass="subtitle" wrapText="true"/>
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>
                <Button fx:id="clearButton" text="Clear log" onAction="#onClear">
                    <graphic><FontIcon iconLiteral="fas-trash"/></graphic>
                </Button>
                <Button fx:id="methodsButton" text="Methods (from log)" onAction="#onMethods" styleClass="primary">
                    <graphic><FontIcon iconLiteral="fas-file-alt"/></graphic>
                </Button>
                <Button fx:id="gatingMethodsButton" text="Methods (from gating tree)" onAction="#onGatingMethods">
                    <graphic><FontIcon iconLiteral="fas-sitemap"/></graphic>
                </Button>
                <Button fx:id="exportCsvButton" text="Export CSV…" onAction="#onExportCsv">
                    <graphic><FontIcon iconLiteral="fas-file-csv"/></graphic>
                </Button>
            </children>
        </HBox>
        <TableView fx:id="logTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="timeCol"   text="Time"      prefWidth="90.0"/>
                <TableColumn fx:id="typeCol"   text="Type"      prefWidth="100.0"/>
                <TableColumn fx:id="sampleCol" text="Sample"    prefWidth="180.0"/>
                <TableColumn fx:id="detailCol" text="Details"   prefWidth="600.0"/>
            </columns>
            <placeholder><Label text="No actions recorded yet. Start gating or run an analysis module."/></placeholder>
        </TableView>
        <Label text="Methods text" styleClass="title"/>
        <TextArea fx:id="methodsArea" editable="false" wrapText="true"
                  prefHeight="140.0" promptText="Click 'Generate Methods Text' to produce a journal-ready paragraph."/>
    </children>
</VBox>
