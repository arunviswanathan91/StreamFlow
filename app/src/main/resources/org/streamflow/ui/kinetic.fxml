<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.streamflow.ui.KineticController"
      styleClass="content" spacing="12.0">
    <children>
        <Label text="Kinetic / Time-Course Analysis" styleClass="title"/>
        <Label text="Bins events by the Time channel and plots median MFI per bin, grouped and averaged with ±SD shading. For calcium flux, oxidative burst, and receptor internalisation assays."
               styleClass="subtitle" wrapText="true"/>
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>
                <Label text="MFI channel:"/>
                <ComboBox fx:id="channelCombo" prefWidth="160.0"/>
                <Label text="Time channel:"/>
                <ComboBox fx:id="timeCombo" prefWidth="130.0"/>
                <Label text="Bins:"/>
                <Spinner fx:id="binsSpinner" editable="true" prefWidth="90.0"/>
                <Button fx:id="refreshButton" text="Refresh" onAction="#onRefresh">
                    <graphic><FontIcon iconLiteral="fas-sync"/></graphic>
                </Button>
                <Button fx:id="runButton" text="Plot" onAction="#onRun" styleClass="primary">
                    <graphic><FontIcon iconLiteral="fas-chart-line"/></graphic>
                </Button>
            </children>
        </HBox>
        <Label fx:id="statusLabel" text="" styleClass="subtitle"/>
        <HBox spacing="12.0" VBox.vgrow="ALWAYS">
            <children>
                <ScrollPane fitToWidth="true" fitToHeight="true" HBox.hgrow="ALWAYS" styleClass="plot-pane">
                    <content>
                        <StackPane>
                            <children>
                                <ImageView fx:id="plotView"/>
                            </children>
                        </StackPane>
                    </content>
                </ScrollPane>
                <VBox spacing="6.0" prefWidth="280.0">
                    <children>
                        <Label text="Samples / Groups" styleClass="title"/>
                        <Label text="Assign samples to groups (one per line):" styleClass="subtitle" wrapText="true"/>
                        <TableView fx:id="sampleTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="sampleCol" text="Sample" prefWidth="160.0"/>
                                <TableColumn fx:id="groupCol"  text="Group"  prefWidth="100.0"/>
                            </columns>
                            <placeholder><Label text="Load FCS files first."/></placeholder>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
