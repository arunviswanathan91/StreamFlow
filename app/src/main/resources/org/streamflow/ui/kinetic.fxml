<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import org.streamflow.ui.AnalysisChart?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.streamflow.ui.KineticController"
      styleClass="content" spacing="12.0">
    <children>
        <Label text="Kinetic / Time-Course Analysis" styleClass="title"/>
        <Label text="Bins events by the Time channel and plots median MFI per bin, grouped and averaged with ±SD shading. For calcium flux, oxidative burst, and receptor internalisation assays."
               styleClass="subtitle" wrapText="true"/>
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>
                <Label text="MFI channel:"/>
                <ComboBox fx:id="channelCombo" prefWidth="150.0"/>
                <Label text="Time channel:"/>
                <ComboBox fx:id="timeCombo" prefWidth="120.0"/>
                <Label text="Gate:"/>
                <ComboBox fx:id="gateCombo" prefWidth="150.0"/>
                <Label text="Bins:"/>
                <ComboBox fx:id="binsCombo" prefWidth="80.0"/>
                <Button fx:id="refreshButton" text="Refresh" onAction="#onRefresh">
                    <graphic><FontIcon iconLiteral="fas-sync"/></graphic>
                </Button>
                <Button fx:id="runButton" text="Plot" onAction="#onRun" styleClass="primary">
                    <graphic><FontIcon iconLiteral="fas-chart-line"/></graphic>
                </Button>
                <Button fx:id="copyButton" text="Copy" onAction="#onCopy">
                    <graphic><FontIcon iconLiteral="fas-copy"/></graphic>
                </Button>
                <Button fx:id="exportButton" text="Export PNG" onAction="#onExport">
                    <graphic><FontIcon iconLiteral="fas-download"/></graphic>
                </Button>
            </children>
        </HBox>
        <Label fx:id="statusLabel" text="" styleClass="subtitle"/>
        <HBox spacing="12.0" VBox.vgrow="ALWAYS">
            <children>
                <AnalysisChart fx:id="chart" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"/>
                <VBox spacing="6.0" prefWidth="260.0" minWidth="220.0" HBox.hgrow="NEVER">
                    <children>
                        <Label text="Samples / Groups" styleClass="title"/>
                        <Label text="Assign samples to groups:" styleClass="subtitle" wrapText="true"/>
                        <TableView fx:id="sampleTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="sampleCol" text="Sample" prefWidth="140.0"/>
                                <TableColumn fx:id="groupCol"  text="Group"  prefWidth="100.0"/>
                            </columns>
                            <placeholder><Label text="Load FCS files first."/></placeholder>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
